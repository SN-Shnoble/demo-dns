# Vite Environment Variables
# Copy this file to .env.development or .env.production and fill in actual values.

# Backend API base URL (no trailing slash). Leave empty in dev to use Vite proxy.
VITE_API_BASE=

# API prefix (default: api/v1)
VITE_API_PREFIX=api/v1

# App metadata
VITE_APP_TITLE=OcerDNS
VITE_APP_ENV=development

# Vite dev server port (omit or set to 5173 for default)
VITE_DEV_PORT=5173

# Vite dev proxy target for the API prefix above.
# Example: http://127.0.0.1:8000 (Laravel artisan serve) or http://127.0.0.1:8081.
# If unset, Vite will NOT proxy /api/* in dev.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
